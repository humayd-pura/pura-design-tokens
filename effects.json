  "gradient/home.bg": {
    "$type": "gradient",
    "$description": "Gradient reserved for home screen background.",
    "$value": {
      "type": "linear",
      "angle": 270,
      "stops": [
        { "color": "{color.primitive.warm.sand.100}", "opacity": 0, "position": 0 },
        { "color": "{Light.ai.default.secondary-subtle}", "position": 1 }
      ]
    }
  },
